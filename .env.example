# LLM Provider Configuration
# Only one of these providers needs to be configured. The system will prioritize in order: Gemini > OpenAI > Ollama

# API backend URL for UI to connect to (default: local)
API_URL="http://localhost:8000"

# 1. Gemini Configuration (Default for Evaluation)
GEMINI_API_KEY="your_gemini_api_key_here"
# MODEL_NAME=gemini-2.5-flash

# 2. OpenAI (or OpenAI-Compatible) Configuration
# OPENAI_API_KEY="your_openai_api_key_here"
# OPENAI_API_BASE="https://api.openai.com/v1"
# MODEL_NAME=gpt-4o-mini

# 3. Ollama Configuration (Local Models)
# OLLAMA_URL="http://localhost:11434"
# MODEL_NAME=llama3.1

# ---------------------------------------------------------
# Retrieval Settings
# ---------------------------------------------------------

# Embedding model to use for vector generation
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# Reranker model for high-precision context extraction
RERANKER_MODEL="BAAI/bge-reranker-base"

# Path to the directory where FAISS vector index and BM25 index will be saved/loaded
FAISS_PATH="./vector_store"
BM25_INDEX_PATH="./vector_store/bm25_index.pkl"

# Minimum Cosine Similarity score (0.0 to 1.0) to consider a retrieved chunk relevant
SIMILARITY_THRESHOLD=0.4

# Chunking Configuration
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=400

# Logging configuration (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
